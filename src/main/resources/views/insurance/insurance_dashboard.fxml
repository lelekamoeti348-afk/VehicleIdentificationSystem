<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vehicle.vis.vehicleidentificationsystem.controllers.InsuranceController">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #48bb78, #38a169); -fx-background-radius: 15;">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        <Label fx:id="welcomeLabel" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Insurance Dashboard" />
        <Label text="Manage insurance policies and claims" style="-fx-text-fill: #e2e8f0; -fx-font-size: 14px;" />
    </VBox>

    <!-- Logout Button -->
    <HBox alignment="CENTER_RIGHT">
        <Button onAction="#handleLogout" text="🚪 Logout" style="-fx-background-color: #f56565; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 5 15;" />
    </HBox>

    <!-- Statistics Cards -->
    <HBox spacing="15">
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="📄 Active Policies" style="-fx-text-fill: #718096; -fx-font-size: 12px;"/>
            <Label fx:id="activePoliciesLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="0"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="⏳ Pending Claims" style="-fx-text-fill: #718096; -fx-font-size: 12px;"/>
            <Label fx:id="pendingClaimsLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="0"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="💰 Total Premium" style="-fx-text-fill: #718096; -fx-font-size: 12px;"/>
            <Label fx:id="totalPremiumLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="M0"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="⚠️ Expiring Soon" style="-fx-text-fill: #718096; -fx-font-size: 12px;"/>
            <Label fx:id="expiringLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="0"/>
        </VBox>
    </HBox>

    <!-- Search and Actions -->
    <HBox spacing="10">
        <TextField fx:id="searchField" promptText="🔍 Search policies..." HBox.hgrow="ALWAYS" style="-fx-background-radius: 20; -fx-padding: 8 15;"/>
        <Button onAction="#newPolicy" text="➕ New Policy" styleClass="btn-success"/>
        <Button onAction="#refreshData" text="🔄 Refresh" styleClass="btn-primary"/>
    </HBox>

    <!-- Policies Table -->
    <Label text="Insurance Policies" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    <TableView fx:id="policiesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colPolicyId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colPolicyNumber" text="Policy Number" prefWidth="150"/>
            <TableColumn fx:id="colVehicleReg" text="Registration" prefWidth="100"/>
            <TableColumn fx:id="colCompany" text="Insurance Company" prefWidth="150"/>
            <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="100"/>
            <TableColumn fx:id="colEndDate" text="End Date" prefWidth="100"/>
            <TableColumn fx:id="colPremium" text="Premium (M)" prefWidth="80"/>
        </columns>
    </TableView>
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button onAction="#editPolicy" text="✏️ Edit Selected" styleClass="btn-warning"/>
        <Button onAction="#deletePolicy" text="🗑️ Delete Selected" styleClass="btn-danger"/>
    </HBox>

    <!-- Claims Table -->
    <Label text="Insurance Claims" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    <TableView fx:id="claimsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colClaimId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colClaimNumber" text="Claim Number" prefWidth="150"/>
            <TableColumn fx:id="colClaimPolicy" text="Policy Number" prefWidth="150"/>
            <TableColumn fx:id="colClaimDate" text="Claim Date" prefWidth="100"/>
            <TableColumn fx:id="colClaimAmount" text="Amount (M)" prefWidth="80"/>
            <TableColumn fx:id="colClaimStatus" text="Status" prefWidth="80"/>
        </columns>
    </TableView>
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button onAction="#processClaim" text="📋 Process New Claim" styleClass="btn-primary"/>
        <Button onAction="#editClaim" text="✏️ Edit Selected" styleClass="btn-warning"/>
        <Button onAction="#deleteClaim" text="🗑️ Delete Selected" styleClass="btn-danger"/>
    </HBox>

</VBox>