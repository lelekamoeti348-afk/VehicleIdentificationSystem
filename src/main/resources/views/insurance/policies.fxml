<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vehicle.vis.vehicleidentificationsystem.controllers.InsuranceController">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <VBox style="-fx-background-color: linear-gradient(to right, #48bb78, #38a169); -fx-background-radius: 15;">
        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
        <Label text="Insurance Policies" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
        <Label text="Manage active and expired policies" style="-fx-text-fill: #e2e8f0; -fx-font-size: 12px;" />
    </VBox>

    <HBox spacing="10">
        <TextField fx:id="policySearchField" promptText="Search by policy number or vehicle..." HBox.hgrow="ALWAYS"/>
        <Button onAction="#newPolicy" text="➕ New Policy" styleClass="btn-success"/>
        <Button onAction="#refreshPolicies" text="🔄 Refresh" styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="policiesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colPolicyNumber" text="Policy Number" prefWidth="150"/>
            <TableColumn fx:id="colVehicleReg" text="Registration" prefWidth="120"/>
            <TableColumn fx:id="colCompany" text="Insurance Company" prefWidth="150"/>
            <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="100"/>
            <TableColumn fx:id="colEndDate" text="End Date" prefWidth="100"/>
            <TableColumn fx:id="colPremium" text="Premium (M)" prefWidth="80"/>
            <TableColumn fx:id="colPolicyStatus" text="Status" prefWidth="80"/>
        </columns>
    </TableView>

</VBox>