<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vehicle.vis.vehicleidentificationsystem.controllers.SettingsController">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Account Settings" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />

    <GridPane hgap="15" vgap="15">
        <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

        <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="usernameLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Full Name:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="fullNameLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="emailLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Current Password:*" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="currentPasswordField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="New Password:*" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="newPasswordField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Confirm Password:*" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="confirmPasswordField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button onAction="#changePassword" text="Change Password" styleClass="btn-primary"/>
        <Button onAction="#refreshSettings" text="Refresh" styleClass="btn-info"/>
    </HBox>

</VBox>