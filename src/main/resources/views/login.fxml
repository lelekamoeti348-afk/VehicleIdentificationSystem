<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootPane" styleClass="login-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vehicle.vis.vehicleidentificationsystem.controllers.LoginController">

    <VBox fx:id="loginCard" alignment="CENTER" maxWidth="450" spacing="25" styleClass="login-card">
        <padding>
            <Insets bottom="50" left="40" right="40" top="50" />
        </padding>

        <VBox alignment="CENTER" spacing="10">
            <Label styleClass="login-title" text="Vehicle Identification System" wrapText="true" />
            <Label style="-fx-font-size: 14px; -fx-text-fill: #718096;" text="Secure Access Portal" />
        </VBox>

        <VBox spacing="8">
            <Label style="-fx-font-size: 14px; -fx-text-fill: #4a5568; -fx-font-weight: bold;" text="Username" />
            <TextField fx:id="usernameField" promptText="Enter your username" styleClass="login-field" />
        </VBox>

        <VBox spacing="8">
            <Label style="-fx-font-size: 14px; -fx-text-fill: #4a5568; -fx-font-weight: bold;" text="Password" />
            <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="login-field" />
        </VBox>

        <Button fx:id="loginButton" onAction="#handleLogin" styleClass="login-button" text="LOGIN">
            <VBox.margin>
                <Insets top="10" />
            </VBox.margin>
        </Button>

        <HBox alignment="CENTER" spacing="15">
            <ProgressIndicator fx:id="loadingIndicator" visible="false" prefHeight="25" prefWidth="25" />
            <Label fx:id="statusLabel" style="-fx-text-fill: #f56565;" />
        </HBox>

        <Button fx:id="exitButton" onAction="#handleExit" style="-fx-background-color: transparent; -fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Exit Application" />
    </VBox>

</StackPane>