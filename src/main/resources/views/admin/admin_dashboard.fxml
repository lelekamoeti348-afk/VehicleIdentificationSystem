<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vehicle.vis.vehicleidentificationsystem.controllers.AdminController">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-background-radius: 15;">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        <Label text="Admin Dashboard" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
        <Label text="System Management &amp; Control Panel" style="-fx-text-fill: #e2e8f0; -fx-font-size: 14px;" />
    </VBox>

    <!-- Logout Button -->
    <HBox alignment="CENTER_RIGHT">
        <Button onAction="#handleLogout" text="🚪 Logout" style="-fx-background-color: #f56565; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 5 15;" />
    </HBox>

    <!-- Statistics Row -->
    <HBox spacing="15">
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15;" HBox.hgrow="ALWAYS">
            <Label text="👥 Total Users" style="-fx-text-fill: #718096;"/>
            <Label fx:id="totalUsersLabel" style="-fx-font-size: 28px; -fx-font-weight: bold;" text="0"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15;" HBox.hgrow="ALWAYS">
            <Label text="🚗 Total Vehicles" style="-fx-text-fill: #718096;"/>
            <Label fx:id="totalVehiclesLabel" style="-fx-font-size: 28px; -fx-font-weight: bold;" text="0"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15;" HBox.hgrow="ALWAYS">
            <Label text="📄 Active Policies" style="-fx-text-fill: #718096;"/>
            <Label fx:id="activePoliciesLabel" style="-fx-font-size: 28px; -fx-font-weight: bold;" text="0"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15;" HBox.hgrow="ALWAYS">
            <Label text="🔧 Services" style="-fx-text-fill: #718096;"/>
            <Label fx:id="totalServicesLabel" style="-fx-font-size: 28px; -fx-font-weight: bold;" text="0"/>
        </VBox>
    </HBox>

    <!-- TabPane: Users + Vehicles -->
    <TabPane VBox.vgrow="ALWAYS">

        <!-- Users Tab -->
        <Tab text="System Users" closable="false">
            <VBox spacing="10">
                <HBox spacing="10">
                    <TextField fx:id="searchField" promptText="Search users..." HBox.hgrow="ALWAYS" styleClass="search-field"/>
                    <Button onAction="#addNewUser" text="➕ Add User" styleClass="btn-success"/>
                    <Button onAction="#deleteUser" text="🗑️ Delete User" styleClass="btn-danger"/>
                    <Button onAction="#refreshUserTable" text="🔄 Refresh" styleClass="btn-primary"/>
                </HBox>
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colUserId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="120"/>
                        <TableColumn fx:id="colFullName" text="Full Name" prefWidth="150"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                        <TableColumn fx:id="colRole" text="Role" prefWidth="100"/>
                        <TableColumn fx:id="colUserStatus" text="Status" prefWidth="80"/>
                    </columns>
                </TableView>
                <Pagination fx:id="userPagination"/>
            </VBox>
        </Tab>

        <!-- Vehicles Tab -->
        <Tab text="Manage Vehicles" closable="false">
            <VBox spacing="10">
                <HBox spacing="10">
                    <TextField fx:id="vehicleSearchField" promptText="Search by registration..." HBox.hgrow="ALWAYS" styleClass="search-field"/>
                    <Button onAction="#addVehicle" text="➕ Add Vehicle" styleClass="btn-success"/>
                    <Button onAction="#refreshVehicleTable" text="🔄 Refresh" styleClass="btn-primary"/>
                </HBox>
                <TableView fx:id="vehicleTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colVehId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colRegNumber" text="Registration" prefWidth="120"/>
                        <TableColumn fx:id="colMake" text="Make" prefWidth="100"/>
                        <TableColumn fx:id="colModel" text="Model" prefWidth="100"/>
                        <TableColumn fx:id="colYear" text="Year" prefWidth="60"/>
                        <TableColumn fx:id="colColor" text="Color" prefWidth="80"/>
                        <TableColumn fx:id="colOwner" text="Owner" prefWidth="120"/>
                        <TableColumn fx:id="colVehStatus" text="Status" prefWidth="80"/>
                    </columns>
                </TableView>
                <Pagination fx:id="vehiclePagination"/>
            </VBox>
        </Tab>

    </TabPane>
</VBox>