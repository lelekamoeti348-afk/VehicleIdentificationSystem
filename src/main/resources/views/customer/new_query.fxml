<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vehicle.vis.vehicleidentificationsystem.controllers.CustomerController">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <VBox style="-fx-background-color: linear-gradient(to right, #4299e1, #3182ce); -fx-background-radius: 15;">
        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
        <Label text="Submit a New Query" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
        <Label text="Get help from support team" style="-fx-text-fill: #e2e8f0; -fx-font-size: 12px;" />
    </VBox>

    <GridPane hgap="15" vgap="15">
        <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

        <Label text="Subject:*" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="subjectField" promptText="Brief summary of your issue" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Vehicle (optional):" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="vehicleCombo" promptText="Select a vehicle" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Priority:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="priorityCombo" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Query Details:*" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextArea fx:id="queryArea" promptText="Describe your issue in detail..." prefRowCount="5" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button onAction="#submitQuery" text="✉️ Submit Query" styleClass="btn-success"/>
        <Button onAction="#cancelQuery" text="Cancel" styleClass="btn-secondary"/>
    </HBox>

</VBox>