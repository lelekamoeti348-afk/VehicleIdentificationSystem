<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vehicle.vis.vehicleidentificationsystem.controllers.CustomerController">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #48bb78, #38a169); -fx-background-radius: 15;">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        <Label fx:id="welcomeLabel" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Customer Dashboard" />
        <Label text="Manage your vehicles, service history, and queries" style="-fx-text-fill: #e2e8f0; -fx-font-size: 14px;" />
    </VBox>

    <!-- Logout Button -->
    <HBox alignment="CENTER_RIGHT">
        <Button onAction="#handleLogout" text="🚪 Logout" style="-fx-background-color: #f56565; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 5 15;" />
    </HBox>

    <!-- Statistics Cards -->
    <HBox spacing="15">
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="🚗 My Vehicles" style="-fx-text-fill: #718096; -fx-font-size: 12px;"/>
            <Label fx:id="vehicleCountLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="0"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="🔧 Service Records" style="-fx-text-fill: #718096; -fx-font-size: 12px;"/>
            <Label fx:id="serviceCountLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="0"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="📄 Active Policies" style="-fx-text-fill: #718096; -fx-font-size: 12px;"/>
            <Label fx:id="policyCountLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="0"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="💬 Pending Queries" style="-fx-text-fill: #718096; -fx-font-size: 12px;"/>
            <Label fx:id="queryCountLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="0"/>
        </VBox>
    </HBox>

    <!-- Action Buttons -->
    <HBox spacing="10">
        <Button fx:id="refreshButton" onAction="#refreshData" text="🔄 Refresh" styleClass="btn-primary"/>
        <Button fx:id="newQueryButton" onAction="#newQuery" text="➕ New Query" styleClass="btn-success"/>
    </HBox>

    <!-- TabPane for different sections -->
    <TabPane VBox.vgrow="ALWAYS">

        <!-- My Vehicles Tab -->
        <Tab text="My Vehicles" closable="false">
            <TableView fx:id="vehiclesTable">
                <columns>
                    <TableColumn fx:id="colRegNumber" text="Registration" prefWidth="120"/>
                    <TableColumn fx:id="colMake" text="Make" prefWidth="100"/>
                    <TableColumn fx:id="colModel" text="Model" prefWidth="100"/>
                    <TableColumn fx:id="colYear" text="Year" prefWidth="60"/>
                    <TableColumn fx:id="colColor" text="Color" prefWidth="80"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                </columns>
            </TableView>
        </Tab>

        <!-- Service History Tab -->
        <Tab text="Service History" closable="false">
            <TableView fx:id="serviceTable">
                <columns>
                    <TableColumn fx:id="colServiceDate" text="Date" prefWidth="100"/>
                    <TableColumn fx:id="colServiceType" text="Service Type" prefWidth="120"/>
                    <TableColumn fx:id="colServiceDesc" text="Description" prefWidth="250"/>
                    <TableColumn fx:id="colServiceCost" text="Cost (M)" prefWidth="80"/>
                    <TableColumn fx:id="colOdometer" text="Odometer" prefWidth="80"/>
                </columns>
            </TableView>
        </Tab>

        <!-- Insurance Policies Tab -->
        <Tab text="Insurance Policies" closable="false">
            <TableView fx:id="policiesTable">
                <columns>
                    <TableColumn fx:id="colPolicyNumber" text="Policy Number" prefWidth="150"/>
                    <TableColumn fx:id="colCompany" text="Insurance Company" prefWidth="150"/>
                    <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="100"/>
                    <TableColumn fx:id="colEndDate" text="End Date" prefWidth="100"/>
                    <TableColumn fx:id="colPremium" text="Premium (M)" prefWidth="80"/>
                    <TableColumn fx:id="colPolicyStatus" text="Status" prefWidth="80"/>
                </columns>
            </TableView>
        </Tab>

        <!-- My Queries Tab -->
        <Tab text="My Queries" closable="false">
            <VBox spacing="10">
                <HBox spacing="10">
                    <Button onAction="#refreshData" text="🔄 Refresh Queries" styleClass="btn-primary"/>
                    <Button onAction="#newQuery" text="➕ New Query" styleClass="btn-success"/>
                    <Button onAction="#editQuery" text="✏️ Edit Selected" styleClass="btn-warning"/>
                    <Button onAction="#deleteQuery" text="🗑️ Delete Selected" styleClass="btn-danger"/>
                </HBox>
                <TableView fx:id="queriesTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colQueryId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colQueryDate" text="Date" prefWidth="120"/>
                        <TableColumn fx:id="colSubject" text="Subject" prefWidth="150"/>
                        <TableColumn fx:id="colQueryText" text="Query" prefWidth="200"/>
                        <TableColumn fx:id="colResponse" text="Response" prefWidth="200"/>
                        <TableColumn fx:id="colQueryStatus" text="Status" prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

    </TabPane>
</VBox>